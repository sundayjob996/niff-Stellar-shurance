# Backend environment variables for NiffyInsure
#
# Source of truth: backend/src/config/env.definitions.ts
# Generate/update: npm run env:example:generate
# Verify drift: npm run env:example:check
#
# Secrets must be distinct per environment (development, staging, production).
# Store production values in your secrets manager, not in this file.
# Example secret backends: HashiCorp Vault, AWS SSM Parameter Store / Secrets Manager, Kubernetes Secrets.
#
# Requirement labels:
#   required    = application boot should fail if missing
#   optional    = only needed when the related feature/integration is enabled
#   conditional = required when another setting enables that integration

# Core
# [required] Runtime environment name used for validation and defaults.
NODE_ENV=development

# [required] HTTP port bound by the Nest API process.
PORT=3000

# [required] Primary PostgreSQL connection string. Use a least-privilege application user for writes. Store in a secrets manager.
DATABASE_URL=postgresql://niffy_app:replace-me@localhost:5432/niffyinsure?schema=public

# [required] Redis connection string for cache, queues, and nonce storage. Store in a secrets manager.
REDIS_URL=redis://localhost:6379/0

# Stellar
# [required] Active Stellar network for RPC, Horizon, and contract resolution.
STELLAR_NETWORK=testnet

# [required] Soroban RPC endpoint for the active network.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# [required] Horizon endpoint for the active network.
HORIZON_URL=https://horizon-testnet.stellar.org

# [required] Canonical network passphrase matching STELLAR_NETWORK.
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# [optional] Default deployed niffyinsure contract ID for the active network.
CONTRACT_ID=

# [optional] Default SEP-41 token contract ID used when no asset override is supplied.
DEFAULT_TOKEN_CONTRACT_ID=

# [optional] Optional per-network RPC override for testnet.
SOROBAN_RPC_URL_TESTNET=

# [optional] Optional per-network RPC override for mainnet.
SOROBAN_RPC_URL_MAINNET=

# [optional] Optional per-network RPC override for futurenet.
SOROBAN_RPC_URL_FUTURENET=

# [optional] Optional per-network Horizon override for testnet.
HORIZON_URL_TESTNET=

# [optional] Optional per-network Horizon override for mainnet.
HORIZON_URL_MAINNET=

# [optional] Optional per-network Horizon override for futurenet.
HORIZON_URL_FUTURENET=

# [optional] Optional per-network contract override for testnet.
CONTRACT_ID_TESTNET=

# [conditional] Optional per-network contract override for mainnet.
CONTRACT_ID_MAINNET=

# [optional] Optional per-network contract override for futurenet.
CONTRACT_ID_FUTURENET=

# [optional] Optional per-network default token contract override for testnet.
DEFAULT_TOKEN_CONTRACT_ID_TESTNET=

# [optional] Optional per-network default token contract override for mainnet.
DEFAULT_TOKEN_CONTRACT_ID_MAINNET=

# [optional] Optional per-network default token contract override for futurenet.
DEFAULT_TOKEN_CONTRACT_ID_FUTURENET=

# [required] Alert when chain head minus last processed ledger exceeds this value.
INDEXER_GAP_ALERT_THRESHOLD_LEDGERS=100

# [required] Minimum milliseconds between repeated indexer gap alerts.
INDEXER_GAP_ALERT_COOLDOWN_MS=3600000

# [optional] Optional Horizon API key for managed providers that require one. Store in a secrets manager.
HORIZON_API_KEY=

# IPFS
# [required] IPFS provider implementation to use.
IPFS_PROVIDER=mock

# [conditional] Pinata API key when IPFS_PROVIDER=pinata. Store in a secrets manager.
PINATA_API_KEY=

# [conditional] Pinata API secret when IPFS_PROVIDER=pinata. Store in a secrets manager.
PINATA_API_SECRET=

# [required] Gateway base URL used for Pinata-backed retrievals.
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# [required] Maximum allowed IPFS upload size in bytes.
IPFS_MAX_FILE_SIZE=52428800

# [required] Minimum allowed IPFS upload size in bytes.
IPFS_MIN_FILE_SIZE=1

# [required] Strip EXIF metadata from supported uploads before pinning.
IPFS_STRIP_EXIF=true

# [required] Public gateway base used for viewing claim evidence.
IPFS_GATEWAY=https://ipfs.io

# [optional] Comma-separated list of allowed IPFS gateway hostnames for evidence URL validation. Defaults to the built-in list when empty. Changes take effect on next deploy (no restart needed for env-only changes).
ALLOWED_IPFS_GATEWAYS=ipfs.io,cloudflare-ipfs.com,gateway.pinata.cloud,dweb.link,nftstorage.link

# [optional] Legacy IPFS project identifier kept for compatibility. Store in a secrets manager.
IPFS_PROJECT_ID=

# [optional] Legacy IPFS project secret kept for compatibility. Store in a secrets manager.
IPFS_PROJECT_SECRET=

# Evidence uploads
# [optional] Maximum allowed claim evidence file size in bytes. Defaults to 10485760 (10 MB).
EVIDENCE_MAX_BYTES=10485760

# [optional] Maximum evidence uploads per wallet per rate-limit window.
EVIDENCE_UPLOAD_RATE_LIMIT=5

# [optional] Evidence upload rate-limit window in seconds.
EVIDENCE_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600

# Auth
# [required] HMAC signing secret for user/admin JWTs. Rotate independently per environment. Store in a secrets manager.
JWT_SECRET=replace-with-64-byte-base64url-key

# [required] JWT access token lifetime.
JWT_EXPIRES_IN=7d

# [required] Refresh token lifetime for legacy auth surfaces.
JWT_REFRESH_EXPIRES_IN=30d

# [required] JWT issuer claim.
JWT_ISSUER=niffyinsure

# [required] JWT audience claim.
JWT_AUDIENCE=niffyinsure-api

# [required] Bootstrap/admin automation token used by operational surfaces. Store in a secrets manager.
ADMIN_TOKEN=replace-with-long-random-admin-token

# [required] Human-readable domain embedded in wallet challenge messages.
AUTH_DOMAIN=app.niffyinsure.local

# [required] Wallet login challenge lifetime in seconds.
NONCE_TTL_SECONDS=300

# [optional] HMAC secret for tamper-resistant pagination cursors. Store in a secrets manager.
PAGINATION_HMAC_SECRET=

# [optional] Incoming JWT signing key for zero-downtime rotation overlap. Set to the new key while JWT_SECRET still holds the current key. Tokens signed by either key are accepted during the overlap window. Remove after all tokens signed with the old JWT_SECRET have expired. Store in a secrets manager.
JWT_SECRET_NEXT=

# HTTP
# [required] Comma-separated public frontend origins allowed by CORS.
FRONTEND_ORIGINS=http://localhost:3001

# [optional] Comma-separated admin UI origins allowed by CORS.
ADMIN_CORS_ORIGINS=http://localhost:3002

# [optional] Canonical combined CORS allowlist. When set, takes precedence over FRONTEND_ORIGINS + ADMIN_CORS_ORIGINS.
CORS_ALLOWED_ORIGINS=

# Observability
# [required] Minimum application log level.
LOG_LEVEL=info

# Caching
# [required] Default cache TTL in seconds for cache-backed reads.
CACHE_TTL_SECONDS=60

# [required] Enable Redis caching for successful quote simulations.
QUOTE_SIMULATION_CACHE_ENABLED=true

# [required] TTL for cached quote simulation results in seconds.
QUOTE_SIMULATION_CACHE_TTL_SECONDS=30

# Support
# [required] CAPTCHA provider for public support/contact forms.
CAPTCHA_PROVIDER=turnstile

# [required] Server-side CAPTCHA verification secret. Store in a secrets manager.
CAPTCHA_SECRET_KEY=dev-skip

# [optional] Public CAPTCHA site key exposed to the frontend.
CAPTCHA_SITE_KEY=

# [required] Salt used when hashing IP addresses for privacy-safe deduplication. Store in a secrets manager.
IP_HASH_SALT=replace-with-random-hex

# Multi-tenancy
# [required] Enable tenant resolution from hostnames/headers.
TENANT_RESOLUTION_ENABLED=false

# [required] Base domain used for subdomain-based tenant resolution.
TENANT_BASE_DOMAIN=niffyinsur.com

# Operations
# [required] Days to retain soft-deleted rows before purge jobs hard-delete them.
DATA_RETENTION_DAYS=730

# [required] Maximum concurrent SSE connections.
SSE_MAX_CONNECTIONS=500

# [required] Enable scheduled solvency monitoring.
SOLVENCY_MONITORING_ENABLED=true

# [required] Cron expression for solvency monitoring runs.
SOLVENCY_CRON_EXPRESSION=0 */15 * * * *

# [required] Minimum treasury buffer before solvency warnings fire.
SOLVENCY_BUFFER_THRESHOLD_STROOPS=0

# [optional] Optional Stellar account used for solvency simulation calls.
SOLVENCY_SIMULATION_SOURCE_ACCOUNT=

# [optional] Optional tenant identifier to scope solvency monitoring.
SOLVENCY_TENANT_ID=

# [optional] Webhook URL that receives solvency alert notifications. Store in a secrets manager.
SOLVENCY_ALERT_WEBHOOK_URL=

# [optional] Shared secret sent with solvency alert webhooks. Store in a secrets manager.
SOLVENCY_ALERT_WEBHOOK_SECRET=

# [optional] Webhook URL that receives wasm drift alerts. Store in a secrets manager.
WASM_DRIFT_WEBHOOK_URL=

# [optional] Shared secret sent with wasm drift alerts. Store in a secrets manager.
WASM_DRIFT_WEBHOOK_SECRET=

# [required] Path to the contract deployment registry JSON file.
DEPLOYMENT_REGISTRY_PATH=contracts/deployment-registry.json

# [optional] Expected SHA-256 hash of the authorised niffyinsure wasm artifact.
NIFFYINSURE_EXPECTED_WASM_HASH=

# [required] Disable the legacy reindex worker in environments where it should not start.
DISABLE_REINDEX_WORKER=0

# [required] Cron expression for renewal reminder background jobs.
RENEWAL_REMINDER_CRON=0 * * * *

# Database
# [required] Maximum Prisma connection pool size.
DB_POOL_MAX=10

# [required] Minimum warm Prisma connections.
DB_POOL_MIN=2

# [required] Idle connection reclaim timeout in milliseconds.
DB_POOL_IDLE_TIMEOUT_MS=30000

# [required] Maximum time to wait for a free DB connection in milliseconds.
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# [required] Warn when an individual DB query exceeds this latency threshold.
DB_SLOW_QUERY_MS=250

# GraphQL
# [required] Enable the GraphQL endpoint.
GRAPHQL_ENABLED=true

# [required] HTTP path mounted for GraphQL requests.
GRAPHQL_PATH=/graphql

# [required] Allow GraphQL schema introspection when NODE_ENV=production.
GRAPHQL_INTROSPECTION_IN_PRODUCTION=false

# [required] Maximum allowed GraphQL selection depth.
GRAPHQL_MAX_DEPTH=8

# [required] Maximum estimated GraphQL query complexity.
GRAPHQL_MAX_COMPLEXITY=250

# [required] Maximum GraphQL operations allowed per rate-limit window.
GRAPHQL_RATE_LIMIT_MAX=60

# [required] GraphQL rate-limit window in milliseconds.
GRAPHQL_RATE_LIMIT_WINDOW_MS=60000

# [required] Warn when a GraphQL operation exceeds this latency threshold.
GRAPHQL_SLOW_OPERATION_MS=750

# [required] Enable Apollo-style automatic persisted queries.
GRAPHQL_PERSISTED_QUERIES_ENABLED=false

# [required] Persisted GraphQL query cache TTL in seconds.
GRAPHQL_PERSISTED_QUERY_TTL_SECONDS=86400

# [required] Default nested policy.claims page size.
GRAPHQL_POLICY_CLAIMS_DEFAULT_LIMIT=10

# [required] Maximum nested policy.claims page size.
GRAPHQL_POLICY_CLAIMS_MAX_LIMIT=25

# Notifications
# [required] SMTP host for outbound email notifications.
SMTP_HOST=127.0.0.1

# [required] SMTP port for outbound email notifications.
SMTP_PORT=1025

# [optional] SMTP username when authenticated mail delivery is enabled. Store in a secrets manager.
SMTP_USER=

# [optional] SMTP password when authenticated mail delivery is enabled. Store in a secrets manager.
SMTP_PASS=

# [required] From address used for outbound notification emails.
SMTP_FROM=no-reply@niffyinsure.local

# [optional] Telegram Bot API token for optional claim notifications. Store in a secrets manager.
TELEGRAM_BOT_TOKEN=

# [optional] Discord webhook URL for optional claim notifications. Store in a secrets manager.
DISCORD_WEBHOOK_URL=

# [optional] Webhook URL for mobile push notifications (policy expiry, claim updates).
# POST requests carry a JSON body: { title, body, data: { type, policyId, expiryLedger } }.
PUSH_WEBHOOK_URL=

# Feature flags
# [optional] JSON object containing backend feature flags.
FEATURE_FLAGS_JSON={"ramp":false}

# [required] HTTP status returned when a feature flag is disabled.
FEATURE_FLAGS_DISABLED_STATUS=404

# Ramp
# [optional] Base URL for the optional fiat on-ramp integration.
RAMP_URL=

# [optional] Comma-separated ISO region codes where the on-ramp is allowed.
RAMP_ALLOWED_REGIONS=

# [required] UTM source appended to ramp URLs.
RAMP_UTM_SOURCE=niffyinsure

# [required] UTM medium appended to ramp URLs.
RAMP_UTM_MEDIUM=app

# [required] UTM campaign appended to ramp URLs.
RAMP_UTM_CAMPAIGN=onramp

# Webhooks
# [optional] GitHub webhook secret for signature verification. Store in a secrets manager.
WEBHOOK_SECRET_GITHUB=

# [optional] Stripe webhook secret for signature verification. Store in a secrets manager.
WEBHOOK_SECRET_STRIPE=

# [optional] Generic webhook secret for signature verification. Store in a secrets manager.
WEBHOOK_SECRET_GENERIC=

# [optional] Optional comma-separated IP allowlist for GitHub webhooks.
WEBHOOK_IP_ALLOWLIST_GITHUB=

# [optional] Optional comma-separated IP allowlist for Stripe webhooks.
WEBHOOK_IP_ALLOWLIST_STRIPE=

# [optional] Optional comma-separated IP allowlist for generic webhooks.
WEBHOOK_IP_ALLOWLIST_GENERIC=
