{
  "name": "niffyinsure-backend",
  "version": "0.1.0",
  "description": "NestJS backend for niff-Stellar-shurance",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:ci": "jest --config ./test/jest-e2e.json --runInBand --forceExit --verbose",
    "refresh-vectors": "ts-node ../scripts/refresh-vectors.ts",
    "docker:build": "docker build -t niffyinsure-backend .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -- -d src/config/database.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -- -d src/config/database.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -- -d src/config/database.ts",
    "seed": "ts-node src/database/seed.ts",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "error-catalog:check": "ts-node scripts/check-error-codes.ts",
    "error-catalog:export": "ts-node scripts/export-error-catalog.ts",
    "env:example:generate": "ts-node scripts/generate-env-example.ts",
    "env:example:check": "ts-node scripts/check-env-example.ts",
    "secrets:generate:jwt": "ts-node scripts/generate-jwt-key.ts",
    "ops:replay-indexer": "ts-node scripts/replay-indexer.ts",
    "export-spec": "ts-node -P tsconfig.json scripts/export-spec.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^6.20.6",
    "@nestjs-modules/ioredis": "^2.1.0",
    "@nestjs/apollo": "13.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^6.6.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@types/form-data": "^2.2.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dompurify": "^3.1.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "formdata-node": "^6.0.3",
    "graphql": "^16.13.2",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^0.12.0",
    "graphql-redis-subscriptions": "^2.7.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "opossum": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^6.6.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.5",
    "winston": "^3.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "10.10.4",
    "@testcontainers/redis": "10.10.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.7",
    "@types/nodemailer": "^6.4.17",
    "@types/opossum": "^8.1.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "fast-check": "^4.6.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "10.10.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0"
  }
}
